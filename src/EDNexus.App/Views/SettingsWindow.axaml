<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EDNexus.App.Views.SettingsWindow"
        Title="EDNexus — Settings"
        Icon="/Assets/ednexus.png"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False" Background="#14161A">
  <StackPanel Margin="24" Spacing="16">
    <TextBlock Text="SETTINGS" Foreground="#F07100" FontSize="12" FontWeight="SemiBold" LetterSpacing="2" />

    <Border Background="#0F1114" CornerRadius="6" Padding="16">
      <StackPanel Spacing="10">
        <CheckBox x:Name="CrashToggle" Content="Send anonymous crash &amp; error reports"
                  Foreground="#E7E9EE" />
        <TextBlock Foreground="#8A909C" FontSize="12" TextWrapping="Wrap"
                   Text="App version, OS, and errors with stack traces, plus a random install id. Never your commander name, systems, journal contents, or user name / paths." />
        <TextBlock x:Name="StatusLine" Foreground="#8A909C" FontSize="11" />
      </StackPanel>
    </Border>

    <TextBlock Text="DATA REPORTING" Foreground="#F07100" FontSize="12" FontWeight="SemiBold" LetterSpacing="2" />

    <Border Background="#0F1114" CornerRadius="6" Padding="16">
      <StackPanel Spacing="10">
        <CheckBox x:Name="EddnToggle" Content="Contribute anonymized data to EDDN"
                  Foreground="#E7E9EE" />
        <TextBlock Foreground="#8A909C" FontSize="12" TextWrapping="Wrap"
                   Text="Uploads market, scan, and travel data to the community Elite Dangerous Data Network. The relay obfuscates your uploader id — no personal identity is shared." />
      </StackPanel>
    </Border>

    <Border Background="#0F1114" CornerRadius="6" Padding="16">
      <StackPanel Spacing="10">
        <CheckBox x:Name="InaraToggle" Content="Sync my commander to Inara"
                  Foreground="#E7E9EE" />
        <TextBlock Foreground="#8A909C" FontSize="12" TextWrapping="Wrap"
                   Text="Sends your identity, credits, ranks, and travel to your Inara profile on session start, docking, and FSD jumps. Requires your personal Inara API key (Inara → Profile → API keys)." />
        <!-- Masked by default: keys get leaked through streams and screenshots, not local attackers. -->
        <Grid ColumnDefinitions="*,Auto">
          <TextBox x:Name="InaraApiKey" PlaceholderText="Inara API key" PasswordChar="●"
                   Foreground="#E7E9EE" Background="#14161A" />
          <CheckBox x:Name="RevealApiKey" Grid.Column="1" Content="Show" Margin="10,0,0,0"
                    Foreground="#8A909C" IsCheckedChanged="OnRevealApiKeyChanged" />
        </Grid>
      </StackPanel>
    </Border>

    <TextBlock Text="UPDATES" Foreground="#F07100" FontSize="12" FontWeight="SemiBold" LetterSpacing="2" />
    <Border Background="#0F1114" CornerRadius="6" Padding="16">
      <StackPanel Spacing="10">
        <CheckBox x:Name="AutoDownloadToggle" Content="Automatically download updates on startup"
                  Foreground="#E7E9EE" />
        <TextBlock Foreground="#8A909C" FontSize="12" TextWrapping="Wrap"
                   Text="When enabled, EDNexus will fetch the latest GitHub release asset for your platform and download it to your temp folder. Installation must still be performed by the user." />

        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="Version:" Foreground="#E7E9EE" VerticalAlignment="Center" />
          <TextBlock x:Name="VersionLine" Foreground="#8A909C" />
          <TextBlock Width="24" />
          <TextBlock Text="Update:" Foreground="#E7E9EE" VerticalAlignment="Center" />
          <TextBlock x:Name="UpdateLine" Foreground="#8A909C" />
        </StackPanel>

        <StackPanel Spacing="6">
          <Button x:Name="CheckNowButton" Content="Check for updates now" Click="OnCheckNow" Padding="10" HorizontalAlignment="Left" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Developer options — hidden entirely when the dev tools are stripped/disabled (FeatureFlags). -->
    <StackPanel x:Name="DevSection" Spacing="8" IsVisible="False">
      <TextBlock Text="DEVELOPER OPTIONS" Foreground="#F07100" FontSize="12" FontWeight="SemiBold" LetterSpacing="2" />
      <Border Background="#0F1114" CornerRadius="6" Padding="16">
        <StackPanel Spacing="10">
          <CheckBox x:Name="DevModeToggle" Content="Enable developer mode" Foreground="#E7E9EE" />
          <TextBlock Foreground="#8A909C" FontSize="12" TextWrapping="Wrap"
                     Text="Adds a 🎲 control to each dashboard card to fabricate random-but-valid state, plus &quot;Randomize all&quot; and &quot;Reset to live data&quot;. For testing only — this resets to off every launch and is not saved. While it is on, EDDN/Inara reporting is paused so fabricated data is never sent." />
        </StackPanel>
      </Border>
    </StackPanel>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Content="Open logs" Click="OnOpenLogs" Padding="16,8" />
      <Button Content="Close" Click="OnClose" Padding="16,8" />
      <Button Content="Save" Click="OnSave" Padding="16,8"
              Background="#F07100" Foreground="#101216" FontWeight="SemiBold" />
    </StackPanel>
  </StackPanel>
</Window>
