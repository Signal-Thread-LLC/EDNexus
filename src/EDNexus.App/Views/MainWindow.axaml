<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EDNexus.App.ViewModels"
        x:Class="EDNexus.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EDNexus — Commander Console"
        Icon="/Assets/ednexus.png"
        Width="980" Height="660" MinWidth="720" MinHeight="480"
        Background="#0A0A0C">

  <Window.Resources>
    <Color x:Key="Amber">#FFF07100</Color>
    <SolidColorBrush x:Key="AmberBrush" Color="#FFF07100" />
    <SolidColorBrush x:Key="AmberDim" Color="#66F07100" />
    <SolidColorBrush x:Key="CardBg" Color="#14161A" />
    <SolidColorBrush x:Key="CardBorder" Color="#242830" />
    <SolidColorBrush x:Key="Ink" Color="#E7E9EE" />
    <SolidColorBrush x:Key="InkDim" Color="#8A909C" />
    <SolidColorBrush x:Key="Good" Color="#FF5FD08B" />
    <SolidColorBrush x:Key="Bad" Color="#FFE0654F" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource CardBg}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="8" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="TextBlock.cardHeader">
      <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="LetterSpacing" Value="2" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource InkDim}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.big">
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.dice">
      <Setter Property="Background" Value="#1B1E24" />
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ToolTip.Tip" Value="Randomize this card" />
    </Style>
    <Style Selector="Button.collapse">
      <Setter Property="Background" Value="#1B1E24" />
      <Setter Property="Foreground" Value="{StaticResource InkDim}" />
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ToolTip.Tip" Value="Collapse / expand" />
    </Style>
    <Style Selector="Button.devbar">
      <Setter Property="Background" Value="#1B1E24" />
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="Padding" Value="12,6" />
    </Style>
    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="#0E1013" />
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Background" Value="{StaticResource AmberBrush}" />
      <Setter Property="Foreground" Value="#101216" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.action:disabled">
      <Setter Property="Background" Value="{StaticResource AmberDim}" />
    </Style>
    <Style Selector="Button.mini">
      <Setter Property="Background" Value="#1B1E24" />
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </Window.Styles>

  <DockPanel LastChildFill="True">

    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="#101216" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,0,0,1" Padding="20,14">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource AmberBrush}" />
          <TextBlock Text="EDNEXUS" Foreground="{StaticResource Ink}" FontSize="18"
                     FontWeight="Bold" LetterSpacing="4" VerticalAlignment="Center" />
          <TextBlock Text="COMMANDER CONSOLE" Foreground="{StaticResource InkDim}" FontSize="11"
                     LetterSpacing="3" VerticalAlignment="Center" Margin="4,3,0,0" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding CommanderName}" Foreground="{StaticResource Ink}"
                       FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Right" />
            <TextBlock Text="{Binding Balance}" Foreground="{StaticResource AmberBrush}"
                       FontSize="13" HorizontalAlignment="Right" />
          </StackPanel>
          <Button Command="{Binding OpenSettingsCommand}" Content="⚙" FontSize="16"
                  Width="36" Height="36" Padding="0" VerticalAlignment="Center"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Background="#1B1E24" Foreground="{StaticResource Ink}" ToolTip.Tip="Settings" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Developer mode action bar -->
    <Border DockPanel.Dock="Top" Background="#141013" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,0,0,1" Padding="20,10" IsVisible="{Binding DevMode}">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <TextBlock Text="DEV MODE" Foreground="{StaticResource AmberBrush}" FontSize="11"
                   FontWeight="SemiBold" LetterSpacing="2" VerticalAlignment="Center" />
        <Button Classes="devbar" Command="{Binding RandomizeAllCommand}" Content="🎲 Randomize all" />
        <Button Classes="devbar" Command="{Binding ResetToLiveCommand}" Content="↺ Reset to live data" />
        <TextBlock Text="Fabricated state is pushed through the real journal pipeline — the 🎲 on each card reshuffles just that card."
                   Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </Border>

    <!-- Update bar (appears when an update has been downloaded) -->
    <Border DockPanel.Dock="Bottom" Background="#112322" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,0,0,1" Padding="12" IsVisible="{Binding UpdateAvailable}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="An update was downloaded" Foreground="{StaticResource Ink}" VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="An update is ready to install" Foreground="{StaticResource Ink}" VerticalAlignment="Center" />
          <Button Content="Install" Command="{Binding InstallUpdateCommand}" Classes="action" Margin="8,0,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Footer / status bar -->
    <Border DockPanel.Dock="Bottom" Background="#101216" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,1,0,0" Padding="20,8">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0" Text="{Binding JournalStatus}" Classes="label"
                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding PrivacyStatus}" Classes="label"
                   Margin="0,0,16,0" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding LastUpdated, StringFormat='updated {0}'}"
                   Classes="label" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Body: one templated card per CardViewModel, laid out in a wrapping flow. -->
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Cards}" Margin="12">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.DataTemplates>

          <!-- Location -->
          <DataTemplate DataType="vm:LocationCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="dice" Content="🎲" Margin="0,0,6,0"
                          IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DevMode}"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RandomizeCardCommand}"
                          CommandParameter="{Binding Id}" />
                  <Button Grid.Column="2" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="big" Text="{Binding SystemName}" />
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                    <TextBlock Classes="label" Text="Body" />
                    <TextBlock Classes="value" FontSize="13" Text="{Binding Body}" />
                  </StackPanel>
                  <TextBlock Classes="value" FontSize="13" Foreground="{StaticResource AmberBrush}"
                             Text="{Binding LocationStatus}" Margin="0,8,0,0" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Ship -->
          <DataTemplate DataType="vm:ShipCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="dice" Content="🎲" Margin="0,0,6,0"
                          IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DevMode}"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RandomizeCardCommand}"
                          CommandParameter="{Binding Id}" />
                  <Button Grid.Column="2" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="value" Text="{Binding Ship}" />
                  <TextBlock Classes="label" Text="Fuel" Margin="0,14,0,4" />
                  <Grid ColumnDefinitions="*,Auto">
                    <ProgressBar Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding FuelFraction}"
                                 Height="8" Foreground="{StaticResource AmberBrush}"
                                 Background="#22262E" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Classes="value" FontSize="13" Margin="12,0,0,0"
                               Text="{Binding Fuel}" />
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Materials -->
          <DataTemplate DataType="vm:MaterialsCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="dice" Content="🎲" Margin="0,0,6,0"
                          IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DevMode}"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RandomizeCardCommand}"
                          CommandParameter="{Binding Id}" />
                  <Button Grid.Column="2" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <Grid ColumnDefinitions="*,*,*">
                    <StackPanel Grid.Column="0">
                      <TextBlock Classes="big" Text="{Binding RawMaterials}" />
                      <TextBlock Classes="label" Text="Raw" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Classes="big" Text="{Binding ManufacturedMaterials}" />
                      <TextBlock Classes="label" Text="Manufactured" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Classes="big" Text="{Binding EncodedMaterials}" />
                      <TextBlock Classes="label" Text="Encoded" />
                    </StackPanel>
                  </Grid>
                  <TextBlock Classes="label" Text="{Binding MaterialsSummary}" Margin="0,10,0,0" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Engineering -->
          <DataTemplate DataType="vm:EngineeringCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">

                  <!-- Picker: shown until a blueprint is pinned -->
                  <StackPanel IsVisible="{Binding NoPin}">
                    <TextBlock Classes="label" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Pin one blueprint to focus on. The card then shows where to unlock its engineer and where to farm each material." />
                    <TextBlock Classes="label" Text="BLUEPRINT" />
                    <ComboBox ItemsSource="{Binding Blueprints}" SelectedItem="{Binding SelectedBlueprint}"
                              HorizontalAlignment="Stretch" Margin="0,2,0,8">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:BlueprintOption">
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                      <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Classes="label" Text="GRADE" />
                        <ComboBox ItemsSource="{Binding GradeChoices}" SelectedItem="{Binding SelectedGrade}"
                                  HorizontalAlignment="Stretch" Margin="0,2,0,0">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="x:Int32">
                              <TextBlock Text="{Binding StringFormat='Grade {0}'}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </StackPanel>
                      <Button Grid.Column="1" Classes="action" Content="Pin goal" VerticalAlignment="Bottom"
                              Command="{Binding PinCommand}" />
                    </Grid>
                  </StackPanel>

                  <!-- Pinned goal -->
                  <StackPanel IsVisible="{Binding HasPin}">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0">
                        <TextBlock Classes="value" Text="{Binding PinnedTitle}" FontSize="15" />
                        <TextBlock Classes="label" Text="{Binding PinnedGradeLabel}"
                                   Foreground="{StaticResource AmberBrush}" />
                      </StackPanel>
                      <Button Grid.Column="1" Classes="mini" Content="Change" VerticalAlignment="Top"
                              Command="{Binding UnpinCommand}" ToolTip.Tip="Unpin and choose a different blueprint" />
                    </Grid>

                    <!-- Engineer -->
                    <Border Background="#0E1013" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10" Margin="0,10,0,10"
                            ToolTip.Tip="{Binding EngineerUnlock}">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                          <TextBlock Classes="label" Text="ENGINEER" />
                          <TextBlock Text="{Binding EngineerName}" Foreground="{StaticResource Ink}"
                                     FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding EngineerLocation}" Classes="label" FontSize="12" />
                          <TextBlock Text="{Binding EngineerStatus}" FontSize="12" Margin="0,2,0,0"
                                     Foreground="{StaticResource Good}" IsVisible="{Binding EngineerUnlocked}" />
                          <TextBlock Text="{Binding EngineerStatus}" FontSize="12" Margin="0,2,0,0"
                                     Foreground="{StaticResource Bad}" IsVisible="{Binding !EngineerUnlocked}" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="mini" Content="Copy system" VerticalAlignment="Center"
                                Command="{Binding CopyEngineerSystemCommand}"
                                ToolTip.Tip="Copy the engineer's system to the clipboard" />
                      </Grid>
                    </Border>

                    <!-- Materials -->
                    <TextBlock Classes="label" Text="{Binding MaterialsSummary}" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding Materials}" MaxHeight="320">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MaterialRow">
                          <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4" ToolTip.Tip="{Binding Source}">
                            <Border Grid.Column="0" Background="#22262E" CornerRadius="4" Padding="6,2" MinWidth="44">
                              <TextBlock Text="{Binding CategoryTag}" Foreground="{StaticResource InkDim}"
                                         FontSize="10" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" Classes="value" FontSize="13"
                                       Margin="10,0,8,0" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                              <TextBlock Text="✓" Foreground="{StaticResource Good}" FontSize="13"
                                         IsVisible="{Binding HasAny}" />
                              <TextBlock Text="{Binding Held}" Classes="value" FontSize="13" MinWidth="34"
                                         TextAlignment="Right" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="label" Text="{Binding OtherEngineers}" TextWrapping="Wrap" Margin="0,8,0,0"
                               IsVisible="{Binding OtherEngineers, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Cargo -->
          <DataTemplate DataType="vm:CargoCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="dice" Content="🎲" Margin="0,0,6,0"
                          IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DevMode}"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RandomizeCardCommand}"
                          CommandParameter="{Binding Id}" />
                  <Button Grid.Column="2" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="value" Text="{Binding CargoSummary}" Margin="0,0,0,10" />
                  <ItemsControl ItemsSource="{Binding Cargo}" MaxHeight="220">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:CargoLine">
                        <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                          <Border Grid.Column="0" Background="#22262E" CornerRadius="4"
                                  Padding="8,2" MinWidth="44">
                            <TextBlock Text="{Binding Count}" Foreground="{StaticResource AmberBrush}"
                                       FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" />
                          </Border>
                          <TextBlock Grid.Column="1" Text="{Binding Name}" Classes="value" FontSize="13"
                                     Margin="10,0,0,0" VerticalAlignment="Center" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Route plotter -->
          <DataTemplate DataType="vm:RouteCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="label" Text="Plot a route between two systems." TextWrapping="Wrap" Margin="0,0,0,8" />

                  <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,4">
                    <RadioButton GroupName="RouteMode" Content="Neutron" IsChecked="{Binding ModeNeutron}" />
                    <RadioButton GroupName="RouteMode" Content="No boost" IsChecked="{Binding ModeNoBoost}" />
                    <RadioButton GroupName="RouteMode" Content="Fleet carrier" IsChecked="{Binding ModeCarrier}" />
                  </StackPanel>
                  <TextBlock Classes="label" Text="{Binding ModeHint}" TextWrapping="Wrap" Margin="0,0,0,10"
                             IsVisible="{Binding ModeHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                  <TextBlock Classes="label" Text="{Binding CarrierFuelText}" TextWrapping="Wrap" Margin="0,0,0,4"
                             Foreground="{StaticResource AmberBrush}"
                             IsVisible="{Binding ShowCarrierFuel}" />
                  <TextBlock Classes="label" Text="{Binding CarrierPendingText}" TextWrapping="Wrap" Margin="0,0,0,10"
                             Foreground="{StaticResource AmberBrush}"
                             IsVisible="{Binding ShowCarrierPending}" />

                  <TextBlock Classes="label" Text="FROM" />
                  <TextBox Classes="field" Text="{Binding RouteFrom}" PlaceholderText="Current system" Margin="0,2,0,8" />
                  <TextBlock Classes="label" Text="TO" />
                  <TextBox Classes="field" Text="{Binding RouteTo}" PlaceholderText="Destination system" Margin="0,2,0,8" />

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <StackPanel Grid.Column="0" Margin="0,0,10,0" IsVisible="{Binding ShowJumpRange}">
                      <TextBlock Classes="label" Text="JUMP RANGE (LY)" />
                      <TextBox Classes="field" Text="{Binding RouteJumpRange}" PlaceholderText="e.g. 48.5" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="action" Content="Plot route" VerticalAlignment="Bottom"
                            Command="{Binding PlotRouteCommand}" IsEnabled="{Binding !RouteBusy}" />
                  </Grid>

                  <TextBlock Classes="label" Text="{Binding RouteStatus}" TextWrapping="Wrap"
                             IsVisible="{Binding RouteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                  <StackPanel IsVisible="{Binding RouteHasPlan}" Margin="0,8,0,0">
                    <TextBlock Classes="label" Text="{Binding RouteSummary}" Margin="0,0,0,10" />

                    <Border Background="#0E1013" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                          <TextBlock Classes="label" Text="NEXT SYSTEM" />
                          <TextBlock Text="{Binding RouteNextSystem}" Foreground="{StaticResource AmberBrush}"
                                     FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="mini" Content="◀" Margin="0,0,6,0"
                                Command="{Binding PrevHopCommand}" ToolTip.Tip="Previous hop" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                          <Button Classes="mini" Content="Copy" Command="{Binding CopyNextSystemCommand}"
                                  ToolTip.Tip="Copy the next system to the clipboard" />
                          <Button Classes="mini" Content="Next ▶" Command="{Binding NextHopCommand}" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RouteHops}" MaxHeight="300">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RouteHopLine">
                          <Grid ColumnDefinitions="18,*,Auto" Margin="0,4">
                            <TextBlock Grid.Column="0" Text="▸" Foreground="{StaticResource AmberBrush}"
                                       FontWeight="Bold" IsVisible="{Binding IsCurrent}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="2,0,8,0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding System}" Classes="value" FontSize="13" TextWrapping="Wrap" />
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Jumps}" Classes="label" FontSize="11" />
                                <TextBlock Text="★ neutron" Foreground="{StaticResource Good}" FontSize="11"
                                           IsVisible="{Binding IsNeutron}" />
                              </StackPanel>
                              <TextBlock Text="{Binding Fuel}" Classes="label" FontSize="11" TextWrapping="Wrap"
                                         IsVisible="{Binding ShowFuel}"
                                         Foreground="{StaticResource AmberBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Remaining}" Classes="label" FontSize="11"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Trade finder -->
          <DataTemplate DataType="vm:TradeCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="label" Text="Best nearby stations to sell a commodity from your hold — or to source one."
                             TextWrapping="Wrap" Margin="0,0,0,10" />

                  <TextBlock Classes="label" Text="COMMODITY" />
                  <TextBox Classes="field" Text="{Binding TradeCommodity}" PlaceholderText="e.g. Low Temperature Diamonds"
                           Margin="0,2,0,8" />
                  <TextBlock Classes="label" Text="NEAR SYSTEM" />
                  <TextBox Classes="field" Text="{Binding TradeReferenceSystem}" PlaceholderText="Current system" Margin="0,2,0,8" />

                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <CheckBox Grid.Column="0" IsChecked="{Binding TradeSelling}" Foreground="{StaticResource Ink}"
                              Content="Selling (offload hold)" VerticalAlignment="Bottom" />
                    <Button Grid.Column="1" Classes="action" Content="Search" VerticalAlignment="Bottom"
                            Command="{Binding SearchTradeCommand}" IsEnabled="{Binding !TradeBusy}" />
                  </Grid>

                  <TextBlock Classes="label" Text="{Binding TradeStatus}" TextWrapping="Wrap"
                             IsVisible="{Binding TradeStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                  <StackPanel IsVisible="{Binding TradeHasResults}" Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,90,70,Auto" Margin="0,0,0,2">
                      <TextBlock Grid.Column="0" Classes="label" Text="STATION" />
                      <TextBlock Grid.Column="1" Classes="label" Text="PRICE" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="2" Classes="label" Text="DIST" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="3" Classes="label" Text="" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding TradeResults}" MaxHeight="320">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TradeResultLine">
                          <Grid ColumnDefinitions="*,90,70,Auto" Margin="0,5">
                            <StackPanel Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Station}" Classes="value" FontSize="13" TextWrapping="Wrap" />
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding System}" Classes="label" FontSize="11" />
                                <TextBlock Text="{Binding Age}" Classes="label" FontSize="11"
                                           Foreground="{StaticResource InkDim}" />
                              </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                              <TextBlock Text="{Binding Price}" Foreground="{StaticResource AmberBrush}" FontSize="13"
                                         FontWeight="Medium" HorizontalAlignment="Right" />
                              <TextBlock Text="{Binding Quantity}" Classes="label" FontSize="11" HorizontalAlignment="Right" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Distance}" Classes="value" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <Button Grid.Column="3" Classes="mini" Content="Copy" Margin="8,0,0,0"
                                    VerticalAlignment="Center" Command="{Binding $parent[ItemsControl].((vm:TradeCardViewModel)DataContext).CopySystemCommand}"
                                    CommandParameter="{Binding System}" ToolTip.Tip="Copy this system" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Colonisation -->
          <DataTemplate DataType="vm:ColonisationCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="dice" Content="🎲" Margin="0,0,6,0"
                          IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DevMode}"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RandomizeCardCommand}"
                          CommandParameter="{Binding Id}" />
                  <Button Grid.Column="2" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="label" IsVisible="{Binding NoColonisation}" TextWrapping="Wrap"
                             Text="No construction site in range. Dock at a colonisation construction ship and open its Construction Services panel to load the depot." />

                  <StackPanel IsVisible="{Binding HasColonisation}">
                    <TextBlock Classes="big" Text="{Binding ColonisationTitle}" TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,4">
                      <ProgressBar Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding ColonisationProgress}"
                                   Height="10" Foreground="{StaticResource AmberBrush}" Background="#22262E"
                                   VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Classes="value" FontSize="15" Margin="12,0,0,0"
                                 Text="{Binding ColonisationStatus}" Foreground="{StaticResource AmberBrush}"
                                 VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Classes="label" Text="{Binding ColonisationSummary}" Margin="0,0,0,12" />

                    <Grid ColumnDefinitions="*,110,100,150" Margin="0,0,0,2">
                      <TextBlock Grid.Column="0" Classes="label" Text="COMMODITY" />
                      <TextBlock Grid.Column="1" Classes="label" Text="REMAINING" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="2" Classes="label" Text="TO BUY" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="3" Classes="label" Text="IN HOLD" HorizontalAlignment="Right" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ShoppingList}" MaxHeight="360">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ShoppingLine">
                          <Grid ColumnDefinitions="*,110,100,150" Margin="0,5">
                            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}" Classes="value" FontSize="13" />
                              <ProgressBar Minimum="0" Maximum="1" Value="{Binding Fraction}" Height="4"
                                           Foreground="{StaticResource AmberDim}" Background="#1B1E24"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Remaining}" Classes="value" FontSize="13"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding ToBuy}" Classes="value" FontSize="13"
                                       Foreground="{StaticResource AmberBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding HoldNote}" FontSize="12"
                                       Foreground="{StaticResource Good}" IsVisible="{Binding Carrying}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

          <!-- Market -->
          <DataTemplate DataType="vm:MarketCardViewModel">
            <Border Classes="card" Width="{Binding Width}" IsVisible="{Binding IsVisible}">
              <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0" Classes="cardHeader" Text="{Binding Title}" />
                  <Button Grid.Column="1" Classes="dice" Content="🎲" Margin="0,0,6,0"
                          IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DevMode}"
                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RandomizeCardCommand}"
                          CommandParameter="{Binding Id}" />
                  <Button Grid.Column="2" Classes="collapse" Content="{Binding CollapseGlyph}"
                          Command="{Binding ToggleCollapseCommand}" />
                </Grid>
                <StackPanel IsVisible="{Binding !IsCollapsed}">
                  <TextBlock Classes="label" IsVisible="{Binding NoMarket}" TextWrapping="Wrap"
                             Text="No market data. Dock at a station and open the Commodities Market to load the board — EDNexus reads it and values your hold here." />

                  <StackPanel IsVisible="{Binding HasMarket}">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Classes="big" Text="{Binding MarketTitle}" TextWrapping="Wrap" />
                        <TextBlock Classes="label" Text="{Binding MarketSummary}" Margin="0,4,0,0" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MarketHoldValue}" Foreground="{StaticResource AmberBrush}"
                                   FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Right" />
                        <TextBlock Classes="label" Text="hold value here" HorizontalAlignment="Right" />
                      </StackPanel>
                    </Grid>

                    <TextBlock Classes="cardHeader" Text="{Binding MarketListHeader}" Margin="0,16,0,6" />
                    <Grid ColumnDefinitions="*,110,130,150,110" Margin="0,0,0,2">
                      <TextBlock Grid.Column="0" Classes="label" Text="COMMODITY" />
                      <TextBlock Grid.Column="1" Classes="label" Text="QTY" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="2" Classes="label" Text="UNIT" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="3" Classes="label" Text="TOTAL" HorizontalAlignment="Right" />
                      <TextBlock Grid.Column="4" Classes="label" Text="VS MEAN" HorizontalAlignment="Right" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding MarketRows}" MaxHeight="360">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MarketLine">
                          <Grid ColumnDefinitions="*,110,130,150,110" Margin="0,5">
                            <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="value" FontSize="13"
                                       Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Qty}" Classes="value" FontSize="13"
                                       Foreground="{StaticResource InkDim}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Unit}" Classes="value" FontSize="13"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding Total}" Classes="value" FontSize="13"
                                       Foreground="{StaticResource AmberBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding VsMean}" FontSize="12"
                                       Foreground="{StaticResource Good}" IsVisible="{Binding Good}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding VsMean}" FontSize="12"
                                       Foreground="{StaticResource Bad}" IsVisible="{Binding Bad}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>

        </ItemsControl.DataTemplates>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
