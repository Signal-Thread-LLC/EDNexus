<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EDNexus.App.ViewModels"
        x:Class="EDNexus.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EDNexus — Commander Console"
        Icon="/Assets/ednexus.png"
        Width="980" Height="660" MinWidth="720" MinHeight="480"
        Background="#0A0A0C">

  <Window.Resources>
    <Color x:Key="Amber">#FFF07100</Color>
    <SolidColorBrush x:Key="AmberBrush" Color="#FFF07100" />
    <SolidColorBrush x:Key="AmberDim" Color="#66F07100" />
    <SolidColorBrush x:Key="CardBg" Color="#14161A" />
    <SolidColorBrush x:Key="CardBorder" Color="#242830" />
    <SolidColorBrush x:Key="Ink" Color="#E7E9EE" />
    <SolidColorBrush x:Key="InkDim" Color="#8A909C" />
    <SolidColorBrush x:Key="Good" Color="#FF5FD08B" />
    <SolidColorBrush x:Key="Bad" Color="#FFE0654F" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource CardBg}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="8" />
    </Style>
    <Style Selector="TextBlock.cardHeader">
      <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="LetterSpacing" Value="2" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource InkDim}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.big">
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.dice">
      <Setter Property="Background" Value="#1B1E24" />
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ToolTip.Tip" Value="Randomize this card" />
    </Style>
    <Style Selector="Button.devbar">
      <Setter Property="Background" Value="#1B1E24" />
      <Setter Property="Foreground" Value="{StaticResource Ink}" />
      <Setter Property="Padding" Value="12,6" />
    </Style>
  </Window.Styles>

  <DockPanel LastChildFill="True">

    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="#101216" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,0,0,1" Padding="20,14">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource AmberBrush}" />
          <TextBlock Text="EDNEXUS" Foreground="{StaticResource Ink}" FontSize="18"
                     FontWeight="Bold" LetterSpacing="4" VerticalAlignment="Center" />
          <TextBlock Text="COMMANDER CONSOLE" Foreground="{StaticResource InkDim}" FontSize="11"
                     LetterSpacing="3" VerticalAlignment="Center" Margin="4,3,0,0" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="14"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding CommanderName}" Foreground="{StaticResource Ink}"
                       FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Right" />
            <TextBlock Text="{Binding Balance}" Foreground="{StaticResource AmberBrush}"
                       FontSize="13" HorizontalAlignment="Right" />
          </StackPanel>
          <Button Command="{Binding OpenSettingsCommand}" Content="⚙" FontSize="16"
                  Width="36" Height="36" Padding="0" VerticalAlignment="Center"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Background="#1B1E24" Foreground="{StaticResource Ink}" ToolTip.Tip="Settings" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Developer mode action bar -->
    <Border DockPanel.Dock="Top" Background="#141013" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,0,0,1" Padding="20,10" IsVisible="{Binding DevMode}">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
        <TextBlock Text="DEV MODE" Foreground="{StaticResource AmberBrush}" FontSize="11"
                   FontWeight="SemiBold" LetterSpacing="2" VerticalAlignment="Center" />
        <Button Classes="devbar" Command="{Binding RandomizeAllCommand}" Content="🎲 Randomize all" />
        <Button Classes="devbar" Command="{Binding ResetToLiveCommand}" Content="↺ Reset to live data" />
        <TextBlock Text="Fabricated state is pushed through the real journal pipeline — the 🎲 on each card reshuffles just that card."
                   Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </Border>

    <!-- Footer / status bar -->
    <Border DockPanel.Dock="Bottom" Background="#101216" BorderBrush="{StaticResource CardBorder}"
            BorderThickness="0,1,0,0" Padding="20,8">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0" Text="{Binding JournalStatus}" Classes="label"
                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding PrivacyStatus}" Classes="label"
                   Margin="0,0,16,0" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding LastUpdated, StringFormat='updated {0}'}"
                   Classes="label" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Body -->
    <ScrollViewer>
      <WrapPanel Margin="12" Orientation="Horizontal">

        <!-- Location -->
        <Border Classes="card" Width="452">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="cardHeader" Text="LOCATION" />
              <Button Grid.Column="1" Classes="dice" Content="🎲" IsVisible="{Binding DevMode}"
                      Command="{Binding RandomizeCardCommand}" CommandParameter="location" />
            </Grid>
            <TextBlock Classes="big" Text="{Binding SystemName}" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
              <TextBlock Classes="label" Text="Body" />
              <TextBlock Classes="value" FontSize="13" Text="{Binding Body}" />
            </StackPanel>
            <TextBlock Classes="value" FontSize="13" Foreground="{StaticResource AmberBrush}"
                       Text="{Binding LocationStatus}" Margin="0,8,0,0" />
          </StackPanel>
        </Border>

        <!-- Ship -->
        <Border Classes="card" Width="452">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="cardHeader" Text="SHIP" />
              <Button Grid.Column="1" Classes="dice" Content="🎲" IsVisible="{Binding DevMode}"
                      Command="{Binding RandomizeCardCommand}" CommandParameter="ship" />
            </Grid>
            <TextBlock Classes="value" Text="{Binding Ship}" />
            <TextBlock Classes="label" Text="Fuel" Margin="0,14,0,4" />
            <Grid ColumnDefinitions="*,Auto">
              <ProgressBar Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding FuelFraction}"
                           Height="8" Foreground="{StaticResource AmberBrush}"
                           Background="#22262E" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Classes="value" FontSize="13" Margin="12,0,0,0"
                         Text="{Binding Fuel}" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Materials -->
        <Border Classes="card" Width="452">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="cardHeader" Text="MATERIALS" />
              <Button Grid.Column="1" Classes="dice" Content="🎲" IsVisible="{Binding DevMode}"
                      Command="{Binding RandomizeCardCommand}" CommandParameter="materials" />
            </Grid>
            <Grid ColumnDefinitions="*,*,*">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="big" Text="{Binding RawMaterials}" />
                <TextBlock Classes="label" Text="Raw" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Classes="big" Text="{Binding ManufacturedMaterials}" />
                <TextBlock Classes="label" Text="Manufactured" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="big" Text="{Binding EncodedMaterials}" />
                <TextBlock Classes="label" Text="Encoded" />
              </StackPanel>
            </Grid>
            <TextBlock Classes="label" Text="{Binding MaterialsSummary}" Margin="0,10,0,0" />
          </StackPanel>
        </Border>

        <!-- Cargo -->
        <Border Classes="card" Width="452">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="cardHeader" Text="CARGO HOLD" />
              <Button Grid.Column="1" Classes="dice" Content="🎲" IsVisible="{Binding DevMode}"
                      Command="{Binding RandomizeCardCommand}" CommandParameter="cargo" />
            </Grid>
            <TextBlock Classes="value" Text="{Binding CargoSummary}" Margin="0,0,0,10" />
            <ItemsControl ItemsSource="{Binding Cargo}" MaxHeight="220">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CargoLine">
                  <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                    <Border Grid.Column="0" Background="#22262E" CornerRadius="4"
                            Padding="8,2" MinWidth="44">
                      <TextBlock Text="{Binding Count}" Foreground="{StaticResource AmberBrush}"
                                 FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" Classes="value" FontSize="13"
                               Margin="10,0,0,0" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Colonisation -->
        <Border Classes="card" Width="920">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="cardHeader" Text="COLONISATION" />
              <Button Grid.Column="1" Classes="dice" Content="🎲" IsVisible="{Binding DevMode}"
                      Command="{Binding RandomizeCardCommand}" CommandParameter="colonisation" />
            </Grid>

            <TextBlock Classes="label" IsVisible="{Binding NoColonisation}" TextWrapping="Wrap"
                       Text="No construction site in range. Dock at a colonisation construction ship and open its Construction Services panel to load the depot." />

            <StackPanel IsVisible="{Binding HasColonisation}">
              <TextBlock Classes="big" Text="{Binding ColonisationTitle}" TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,4">
                <ProgressBar Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding ColonisationProgress}"
                             Height="10" Foreground="{StaticResource AmberBrush}" Background="#22262E"
                             VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Classes="value" FontSize="15" Margin="12,0,0,0"
                           Text="{Binding ColonisationStatus}" Foreground="{StaticResource AmberBrush}"
                           VerticalAlignment="Center" />
              </Grid>
              <TextBlock Classes="label" Text="{Binding ColonisationSummary}" Margin="0,0,0,12" />

              <Grid ColumnDefinitions="*,110,100,150" Margin="0,0,0,2">
                <TextBlock Grid.Column="0" Classes="label" Text="COMMODITY" />
                <TextBlock Grid.Column="1" Classes="label" Text="REMAINING" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="2" Classes="label" Text="TO BUY" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Classes="label" Text="IN HOLD" HorizontalAlignment="Right" />
              </Grid>

              <ItemsControl ItemsSource="{Binding ShoppingList}" MaxHeight="360">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ShoppingLine">
                    <Grid ColumnDefinitions="*,110,100,150" Margin="0,5">
                      <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" Classes="value" FontSize="13" />
                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding Fraction}" Height="4"
                                     Foreground="{StaticResource AmberDim}" Background="#1B1E24"
                                     Margin="0,4,0,0" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding Remaining}" Classes="value" FontSize="13"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding ToBuy}" Classes="value" FontSize="13"
                                 Foreground="{StaticResource AmberBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="3" Text="{Binding HoldNote}" FontSize="12"
                                 Foreground="{StaticResource Good}" IsVisible="{Binding Carrying}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Market -->
        <Border Classes="card" Width="920">
          <StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="cardHeader" Text="MARKET" />
              <Button Grid.Column="1" Classes="dice" Content="🎲" IsVisible="{Binding DevMode}"
                      Command="{Binding RandomizeCardCommand}" CommandParameter="market" />
            </Grid>

            <TextBlock Classes="label" IsVisible="{Binding NoMarket}" TextWrapping="Wrap"
                       Text="No market data. Dock at a station and open the Commodities Market to load the board — EDNexus reads it and values your hold here." />

            <StackPanel IsVisible="{Binding HasMarket}">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                  <TextBlock Classes="big" Text="{Binding MarketTitle}" TextWrapping="Wrap" />
                  <TextBlock Classes="label" Text="{Binding MarketSummary}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <TextBlock Text="{Binding MarketHoldValue}" Foreground="{StaticResource AmberBrush}"
                             FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Right" />
                  <TextBlock Classes="label" Text="hold value here" HorizontalAlignment="Right" />
                </StackPanel>
              </Grid>

              <TextBlock Classes="cardHeader" Text="{Binding MarketListHeader}" Margin="0,16,0,6" />
              <Grid ColumnDefinitions="*,110,130,150,110" Margin="0,0,0,2">
                <TextBlock Grid.Column="0" Classes="label" Text="COMMODITY" />
                <TextBlock Grid.Column="1" Classes="label" Text="QTY" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="2" Classes="label" Text="UNIT" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Classes="label" Text="TOTAL" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="4" Classes="label" Text="VS MEAN" HorizontalAlignment="Right" />
              </Grid>

              <ItemsControl ItemsSource="{Binding MarketRows}" MaxHeight="360">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:MarketLine">
                    <Grid ColumnDefinitions="*,110,130,150,110" Margin="0,5">
                      <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="value" FontSize="13"
                                 Margin="0,0,12,0" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding Qty}" Classes="value" FontSize="13"
                                 Foreground="{StaticResource InkDim}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="2" Text="{Binding Unit}" Classes="value" FontSize="13"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="3" Text="{Binding Total}" Classes="value" FontSize="13"
                                 Foreground="{StaticResource AmberBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="4" Text="{Binding VsMean}" FontSize="12"
                                 Foreground="{StaticResource Good}" IsVisible="{Binding Good}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="4" Text="{Binding VsMean}" FontSize="12"
                                 Foreground="{StaticResource Bad}" IsVisible="{Binding Bad}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </Border>

      </WrapPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
