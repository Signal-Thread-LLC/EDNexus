  <name>EDNexus</name>
  <summary>Elite Dangerous commander console</summary>
  <developer id="io.github.Signal_Thread_LLC">
    <name>Signal &amp; Thread, LLC</name>
  </developer>
  <description>
    <p>
      EDNexus is a companion app for Elite Dangerous that reads your game journal to drive
      market, trade-route, exobiology and colonisation tools.
    </p>
    <p>
      On Linux it auto-detects the journals the game writes under Steam Proton, so it runs
      alongside your existing install on both desktops and the Steam Deck — no need to run
      the companion app itself through Wine.
    </p>
  </description>
  <launchable type="desktop-id">io.github.Signal_Thread_LLC.EDNexus.desktop</launchable>
